generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer :6543)
  directUrl = env("DIRECT_URL")   // direct (:5432) for migrations
}

// --- Sessions (Academic Years) ---
model Session {
  id        Int         @id @default(autoincrement())
  name      String      @unique // "2024-2025"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean     @default(false)
  students  Student[]
  oldPromos Promotion[] @relation("OldSession")
  newPromos Promotion[] @relation("NewSession")
  createdAt DateTime    @default(now())

  @@map("sessions")
}

// --- Classes ---
model Class {
  id        Int         @id @default(autoincrement())
  name      String
  section   String?
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  students  Student[]
  oldPromos Promotion[] @relation("OldClass")
  newPromos Promotion[] @relation("NewClass")

  @@unique([name, section])
  @@map("classes")
}

// --- Students ---
model Student {
  id          Int         @id @default(autoincrement())
  admissionNo String      @unique
  name        String
  fatherName  String
  dob         DateTime?
  gender      Gender      @default(MALE)
  contactNo   String?
  address     String?
  photoUrl    String?
  status      Status      @default(ACTIVE)
  classId     Int
  sessionId   Int
  class       Class       @relation(fields: [classId], references: [id])
  session     Session     @relation(fields: [sessionId], references: [id])
  promotions  Promotion[]
  vouchers    Voucher[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdBy   String?
  deletedAt   DateTime?

  @@index([classId])
  @@index([sessionId])
  @@index([status])
  @@index([deletedAt])
  @@index([classId, sessionId, status])
  @@map("students")
}

// --- Promotions ---
model Promotion {
  id           Int      @id @default(autoincrement())
  studentId    Int
  oldClassId   Int
  newClassId   Int
  oldSessionId Int
  newSessionId Int
  promotedAt   DateTime @default(now())
  promotedBy   String
  batchId      String
  remarks      String?
  student      Student  @relation(fields: [studentId], references: [id])
  oldClass     Class    @relation("OldClass", fields: [oldClassId], references: [id])
  newClass     Class    @relation("NewClass", fields: [newClassId], references: [id])
  oldSession   Session  @relation("OldSession", fields: [oldSessionId], references: [id])
  newSession   Session  @relation("NewSession", fields: [newSessionId], references: [id])

  @@unique([studentId, oldSessionId])
  @@index([batchId])
  @@map("promotions")
}

// --- Vouchers ---
model Voucher {
  id          Int           @id @default(autoincrement())
  voucherNo   String        @unique
  studentId   Int
  voucherDate DateTime      @default(now())
  dueDate     DateTime
  amount      Decimal       @db.Decimal(10, 2)
  feeMonth    String?
  status      VoucherStatus @default(PENDING)
  remarks     String?
  pdfUrl      String?
  printedAt   DateTime?
  printedBy   String?
  student     Student       @relation(fields: [studentId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([feeMonth])
  @@map("vouchers")
}

// --- Voucher Sequence (gap-tolerant, race-safe numbering) ---
model VoucherSequence {
  id        Int @id @default(1)
  lastValue Int @default(0)

  @@map("voucher_sequence")
}

// --- Audit Log ---
model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String
  username  String
  action    String
  tableName String
  recordId  Int?
  oldValues Json?
  newValues Json?
  requestId String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([tableName])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Status {
  ACTIVE
  INACTIVE
  LEFT
}

enum VoucherStatus {
  PENDING
  PAID
  CANCELLED
}
