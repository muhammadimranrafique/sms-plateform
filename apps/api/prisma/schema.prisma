generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean     @default(false)
  students  Student[]
  oldPromos Promotion[] @relation("OldSession")
  newPromos Promotion[] @relation("NewSession")
  feeStructures FeeStructure[]
  feeCharges FeeCharge[]
  lateFineRules LateFineRule[]
  promotionRules PromotionRule[]
  defaulterAlerts DefaulterAlert[]
  createdAt DateTime    @default(now())

  @@map("sessions")
}

model Class {
  id        Int         @id @default(autoincrement())
  name      String
  section   String?
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  students  Student[]
  oldPromos Promotion[] @relation("OldClass")
  newPromos Promotion[] @relation("NewClass")
  feeStructures FeeStructure[]

  @@unique([name, section])
  @@map("classes")
}

model Student {
  id          Int         @id @default(autoincrement())
  admissionNo String      @unique
  registrationNumber String?
  name        String
  fatherName  String
  motherName  String?
  dob         DateTime?
  gender      Gender      @default(MALE)
  bloodGroup  String?
  contactNo   String?
  address     String?
  photoUrl    String?
  admissionDate DateTime?
  status      Status      @default(ACTIVE)
  classId     Int
  sessionId   Int
  class       Class       @relation(fields: [classId], references: [id])
  session     Session     @relation(fields: [sessionId], references: [id])
  promotions  Promotion[]
  vouchers    Voucher[]
  feeCharges  FeeCharge[]
  payments    Payment[]
  studentLedger StudentLedger?
  discounts   Discount[]
  concessions StudentConcession[]
  defaulterAlerts DefaulterAlert[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdBy   String?
  deletedAt   DateTime?

  @@index([classId])
  @@index([sessionId])
  @@index([status])
  @@index([deletedAt])
  @@index([classId, sessionId, status])
  @@index([admissionNo])
  @@index([name])
  @@index([admissionDate])
  @@map("students")
}

model FeeHead {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  code        String      @unique
  description String?
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  items       FeeStructureItem[]
  charges     FeeCharge[]
  lines       VoucherLine[]
  discounts   Discount[]
  concessions StudentConcession[]
  createdAt   DateTime    @default(now())

  @@map("fee_heads")
}

model FeeStructure {
  id        Int                @id @default(autoincrement())
  name      String
  classId   Int
  sessionId Int
  class     Class              @relation(fields: [classId], references: [id])
  session   Session            @relation(fields: [sessionId], references: [id])
  items     FeeStructureItem[]
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([classId, sessionId])
  @@index([classId])
  @@index([sessionId])
  @@map("fee_structures")
}

model FeeStructureItem {
  id             Int          @id @default(autoincrement())
  feeStructureId Int
  feeHeadId      Int
  amount         Decimal      @db.Decimal(10, 2)
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  feeHead        FeeHead      @relation(fields: [feeHeadId], references: [id])

  @@unique([feeStructureId, feeHeadId])
  @@map("fee_structure_items")
}

model FeeCharge {
  id         Int          @id @default(autoincrement())
  studentId  Int
  feeHeadId  Int
  sessionId  Int
  voucherId  Int?
  feeMonth   String
  amount     Decimal      @db.Decimal(10, 2)
  dueDate    DateTime
  fine       Decimal      @default(0) @db.Decimal(10, 2)
  paidAmount Decimal      @default(0) @db.Decimal(10, 2)
  status     ChargeStatus @default(UNPAID)
  version    Int          @default(0)
  student    Student      @relation(fields: [studentId], references: [id])
  feeHead    FeeHead      @relation(fields: [feeHeadId], references: [id])
  session    Session      @relation(fields: [sessionId], references: [id])
  voucher    Voucher?     @relation(fields: [voucherId], references: [id])
  payments   FeePayment[]
  allocations PaymentAllocation[]
  createdAt  DateTime     @default(now())

  @@index([studentId, sessionId])
  @@index([feeMonth])
  @@index([feeHeadId])
  @@index([voucherId])
  @@index([studentId, sessionId, dueDate])
  @@map("fee_charges")
}

model LateFineRule {
  id        Int          @id @default(autoincrement())
  sessionId Int
  name      String
  graceDays Int          @default(0)
  type      LateFineType @default(FIXED)
  value     Decimal      @db.Decimal(10, 2)
  maxFine   Decimal?     @db.Decimal(10, 2)
  isActive  Boolean      @default(true)
  session   Session      @relation(fields: [sessionId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([sessionId])
  @@map("late_fine_rules")
}

model Payment {
  id          Int              @id @default(autoincrement())
  studentId   Int
  amount      Decimal          @db.Decimal(10, 2)
  method      FeePaymentMethod
  referenceNo String?
  paidAt      DateTime
  receivedBy  String?
  status      PaymentStatus    @default(COMPLETED)
  reversedAt  DateTime?
  reversedBy  String?
  remarks     String?
  student     Student          @relation(fields: [studentId], references: [id])
  allocations PaymentAllocation[]
  createdAt   DateTime         @default(now())

  @@index([studentId])
  @@index([studentId, paidAt])
  @@map("payments")
}

model PaymentAllocation {
  id          Int       @id @default(autoincrement())
  paymentId   Int
  feeChargeId Int
  amount      Decimal   @db.Decimal(10, 2)
  finePaid    Decimal   @default(0) @db.Decimal(10, 2)
  payment     Payment   @relation(fields: [paymentId], references: [id])
  feeCharge   FeeCharge @relation(fields: [feeChargeId], references: [id])

  @@unique([paymentId, feeChargeId])
  @@index([feeChargeId])
  @@map("payment_allocations")
}

model StudentLedger {
  id        Int      @id @default(autoincrement())
  studentId Int      @unique
  advance   Decimal  @default(0) @db.Decimal(10, 2)
  student   Student  @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("student_ledgers")
}

model FeePayment {
  id          Int       @id @default(autoincrement())
  feeChargeId Int
  amount      Decimal   @db.Decimal(10, 2)
  paidAt      DateTime  @default(now())
  method      FeePaymentMethod @default(CASH)
  referenceNo String?
  receivedBy  String?
  feeCharge   FeeCharge @relation(fields: [feeChargeId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([feeChargeId])
  @@map("fee_payments")
}

model Discount {
  id         Int       @id @default(autoincrement())
  studentId  Int
  feeHeadId  Int?
  type       DiscountType @default(PERCENTAGE)
  value      Decimal   @db.Decimal(10, 2)
  reason     String?
  approvedBy String?
  validFrom  DateTime?
  validUntil DateTime?
  isActive   Boolean   @default(true)
  student    Student   @relation(fields: [studentId], references: [id])
  feeHead    FeeHead?  @relation(fields: [feeHeadId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([studentId])
  @@map("discounts")
}

model PromotionRule {
  id                   Int       @id @default(autoincrement())
  name                 String
  sessionId            Int
  passPercentage       Decimal   @default(40) @db.Decimal(5, 2)
  feeClearanceRequired Boolean   @default(true)
  isActive             Boolean   @default(true)
  session              Session   @relation(fields: [sessionId], references: [id])
  batches              PromotionBatch[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([sessionId])
  @@index([isActive])
  @@map("promotion_rules")
}

model PromotionBatch {
  id         String     @id
  status     BatchStatus @default(EXECUTED)
  promotedBy String
  remarks    String?
  ruleId     Int?
  rule       PromotionRule? @relation(fields: [ruleId], references: [id])
  promotions Promotion[]
  executedAt DateTime   @default(now())
  revertedAt DateTime?
  revertedBy String?

  @@index([status])
  @@map("promotion_batches")
}

model Promotion {
  id           Int             @id @default(autoincrement())
  studentId    Int
  oldClassId   Int
  newClassId   Int
  oldSessionId Int
  newSessionId Int
  promotedAt   DateTime        @default(now())
  promotedBy   String
  batchId      String
  remarks      String?
  student      Student         @relation(fields: [studentId], references: [id])
  oldClass     Class           @relation("OldClass", fields: [oldClassId], references: [id])
  newClass     Class           @relation("NewClass", fields: [newClassId], references: [id])
  oldSession   Session         @relation("OldSession", fields: [oldSessionId], references: [id])
  newSession   Session         @relation("NewSession", fields: [newSessionId], references: [id])
  batch        PromotionBatch  @relation(fields: [batchId], references: [id])

  @@unique([studentId, oldSessionId])
  @@index([batchId])
  @@map("promotions")
}

model Voucher {
  id          Int            @id @default(autoincrement())
  voucherNo   String         @unique
  studentId   Int
  voucherDate DateTime       @default(now())
  dueDate     DateTime
  amount      Decimal        @db.Decimal(10, 2)
  feeMonth    String?
  status      VoucherStatus  @default(PENDING)
  lateFine    Decimal        @default(0) @db.Decimal(10, 2)
  discount    Decimal        @default(0) @db.Decimal(10, 2)
  arrears     Decimal        @default(0) @db.Decimal(10, 2)
  netAmount   Decimal        @default(0) @db.Decimal(10, 2)
  remarks     String?
  pdfUrl      String?
  printedAt   DateTime?
  printedBy   String?
  student     Student        @relation(fields: [studentId], references: [id])
  lines       VoucherLine[]
  feeCharges  FeeCharge[]
  printLogs   VoucherPrintLog[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([feeMonth])
  @@index([studentId, feeMonth, status])
  @@map("vouchers")
}

model VoucherLine {
  id          Int      @id @default(autoincrement())
  voucherId   Int
  feeHeadId   Int
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  voucher     Voucher  @relation(fields: [voucherId], references: [id])
  feeHead     FeeHead  @relation(fields: [feeHeadId], references: [id])

  @@index([voucherId])
  @@map("voucher_lines")
}

model VoucherSequence {
  id        Int @id @default(1)
  lastValue Int @default(0)

  @@map("voucher_sequence")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String
  username  String
  action    String
  tableName String
  recordId  Int?
  oldValues Json?
  newValues Json?
  requestId String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([tableName])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ======== FEE CONCESSION / SCHOLARSHIP ========

model FeeConcession {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  type        ConcessionType     @default(PERCENTAGE)
  value       Decimal            @db.Decimal(10, 2)
  description String?
  criteria    Json?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  assignments StudentConcession[]

  @@map("fee_concessions")
}

model StudentConcession {
  id           Int              @id @default(autoincrement())
  studentId    Int
  concessionId Int
  feeHeadId    Int?
  startMonth   String
  endMonth     String?
  approvedBy   String
  approvedAt   DateTime         @default(now())
  remarks      String?
  student      Student          @relation(fields: [studentId], references: [id])
  concession   FeeConcession    @relation(fields: [concessionId], references: [id])
  feeHead      FeeHead?         @relation(fields: [feeHeadId], references: [id])

  @@unique([studentId, concessionId, feeHeadId, startMonth])
  @@index([studentId])
  @@index([concessionId])
  @@map("student_concessions")
}

// ======== FEE AGGREGATION (Daily Rollup) ========

model FeeAggregationDaily {
  id              BigInt     @id @default(autoincrement())
  date            DateTime
  classId         Int?
  sessionId       Int?
  feeHeadId       Int?
  totalAssigned   Decimal    @db.Decimal(14, 2)
  totalPaid       Decimal    @db.Decimal(14, 2)
  totalFine       Decimal    @db.Decimal(14, 2)
  totalDiscount   Decimal    @db.Decimal(14, 2)
  totalConcession Decimal    @db.Decimal(14, 2) @default(0)
  totalOutstanding Decimal   @db.Decimal(14, 2)
  studentCount    Int
  paidCount       Int
  partialCount    Int
  overdueCount    Int
  unpaidCount     Int

  @@index([date])
  @@index([date, classId])
  @@index([sessionId, classId])
  @@map("fee_aggregation_daily")
}

// ======== DEFAULTER ALERTS ========

model DefaulterAlert {
  id          Int          @id @default(autoincrement())
  studentId   Int
  sessionId   Int
  overdueDays Int
  amountDue   Decimal      @db.Decimal(10, 2)
  alertLevel  AlertLevel
  status      AlertStatus  @default(ACTIVE)
  notifiedAt  DateTime?
  notifiedVia String?
  resolvedAt  DateTime?
  resolvedBy  String?
  remarks     String?
  student     Student      @relation(fields: [studentId], references: [id])
  session     Session      @relation(fields: [sessionId], references: [id])
  createdAt   DateTime     @default(now())

  @@index([studentId, status])
  @@index([sessionId, alertLevel, status])
  @@index([status, createdAt])
  @@map("defaulter_alerts")
}

// ======== CHEQUE BOUNCE FEE RULE ========

model BounceFeeRule {
  id        Int       @id @default(autoincrement())
  name      String
  fee       Decimal   @db.Decimal(10, 2) @default(500)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@map("bounce_fee_rules")
}

// ======== VOUCHER REPRINT TRACKING ========

model VoucherPrintLog {
  id        BigInt   @id @default(autoincrement())
  voucherId Int
  printedBy String
  printType String
  printedAt DateTime @default(now())
  voucher   Voucher  @relation(fields: [voucherId], references: [id])

  @@index([voucherId])
  @@map("voucher_print_logs")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Status {
  ACTIVE
  INACTIVE
  LEFT
}

enum VoucherStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum ChargeStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum FeePaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum PaymentStatus {
  COMPLETED
  REVERSED
}

enum LateFineType {
  FIXED
  PERCENTAGE
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BatchStatus {
  EXECUTED
  ROLLED_BACK
}

enum ConcessionType {
  PERCENTAGE
  FIXED
}

enum AlertLevel {
  YELLOW
  ORANGE
  RED
}

enum AlertStatus {
  ACTIVE
  RESOLVED
  DISMISSED
}
