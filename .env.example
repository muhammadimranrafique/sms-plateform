# Copy to apps/api/.env and apps/web/.env.local and fill in real values.
# NEVER commit real secrets. The service-role key must never appear in any NEXT_PUBLIC_* var.

# ---- API (apps/api/.env) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sms?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/sms?schema=public"
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="REPLACE_ME_SERVER_ONLY"
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
LOG_LEVEL=info
SENTRY_DSN=""

# ---- Web (apps/web/.env.local) ----
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="REPLACE_ME_ANON_KEY"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SCHOOL_NAME="Your School Name"
